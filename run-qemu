#!/usr/bin/env bash

# Configurable variables — all can be overridden via environment variables
FUJINET_FIRMWARE_PATH=${FUJINET_FIRMWARE_PATH:-../fujinet-firmware}
PKILL_ENABLED=${PKILL_ENABLED:-true}
MEMORY=${MEMORY:-64}
HDA=${HDA:-msdos.qcow2}
FUJINET_PORT=${FUJINET_PORT:-65504}
FDA=${FDA:-}
BOOT=${BOOT:-c}

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Start FujiNet and launch QEMU for MS-DOS emulation.

Options:
  -m, --memory <MB>       RAM for the QEMU machine (env: MEMORY, default: 64)
  -d, --hda <image>       Hard disk image (env: HDA, default: msdos.qcow2)
  -f, --fda <image>       Floppy disk image (env: FDA, default: none)
  -b, --boot <device>     Boot device: c=hard disk, a=floppy (env: BOOT, default: c)
  -p, --port <port>       FujiNet network port (env: FUJINET_PORT, default: 65504)
  -F, --fujinet-path <p>  Path to fujinet-firmware repo (env: FUJINET_FIRMWARE_PATH,
                          default: ../fujinet-firmware)
  -n, --no-pkill          Skip killing existing fujinet processes
                          (env: PKILL_ENABLED=false)
  -h, --help              Show this help message
EOF
}

# Parse flags
while [[ $# -gt 0 ]]; do
    case $1 in
        -m|--memory)
            MEMORY=$2; shift 2 ;;
        -d|--hda)
            HDA=$2; shift 2 ;;
        -f|--fda)
            FDA=$2; shift 2 ;;
        -b|--boot)
            BOOT=$2; shift 2 ;;
        -p|--port)
            FUJINET_PORT=$2; shift 2 ;;
        -F|--fujinet-path)
            FUJINET_FIRMWARE_PATH=$2; shift 2 ;;
        -n|--no-pkill)
            PKILL_ENABLED=false; shift ;;
        -h|--help)
            usage; exit 0 ;;
        *)
            echo "Unknown option: $1" >&2
            echo >&2
            usage >&2
            exit 1 ;;
    esac
done

# Ensure fujinet symlink points to the configured firmware distfiles
FUJINET_DISTFILES="$FUJINET_FIRMWARE_PATH/build/dist"
if [[ "$(readlink fujinet)" != "$FUJINET_DISTFILES" ]]; then
    rm -f fujinet
    ln -s "$FUJINET_DISTFILES" fujinet
fi

if [[ "$PKILL_ENABLED" == "true" ]]; then
    pkill -f fujinet
fi

# Update the BOIP port in fnconfig.ini
sed -i "/^\[BOIP\]/,/^\[/{s/^port=.*/port=$FUJINET_PORT/}" fujinet/fnconfig.ini

# Start FujiNet in the background
(cd fujinet && ./run-fujinet) &
FUJINET_PID=$!
trap 'kill "$FUJINET_PID" 2>/dev/null' EXIT

# Wait for FujiNet to be ready (listening on configured port)
echo "Waiting for FujiNet to start..."
while ! nc -z localhost "$FUJINET_PORT" 2>/dev/null; do
    sleep 0.5
done
echo "FujiNet started."

QEMU_ARGS=(-hda "$HDA" -m "$MEMORY" -L .
    -chardev socket,id=fujinet,host=localhost,port="$FUJINET_PORT",reconnect-ms=1000
    -serial chardev:fujinet
    -boot "$BOOT")

[[ -n "$FDA" ]] && QEMU_ARGS+=(-fda "$FDA")

qemu-system-i386 "${QEMU_ARGS[@]}"
